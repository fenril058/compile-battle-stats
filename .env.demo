# ローカル開発（手動 UI 確認）用。`npm run dev:local`（vite --mode demo）で読み込む。
# Firebase 設定を空にして FIREBASE_CONFIG=null を強制し、本番 Firestore に一切触れない
# LocalStorage モードで起動する。本番データを見たいときは CSV を import すればよい。
# 本番 Firestore に実接続して確認したいときだけ `npm run dev`（.env=本番）を使う。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
