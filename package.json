{
  "name": "compile-battle-stats",
  "private": true,
  "version": "2.6.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode demo",
    "build": "tsc -b && vite build",
    "check": "biome check",
    "check:fix": "biome check --write",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:staged": "vitest run related --changed",
    "test:emulator": "firebase emulators:exec --only firestore --project demo-compile 'vitest run --config vitest.emulator.config.ts'",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "react-toastify": "^11.1.0",
    "secretlint": "^13.0.2",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-beasties": "^0.4.2",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*": [
      "secretlint"
    ]
  }
}
