# 単体テスト（Vitest, mode=test）用の環境設定。
# Firebase 設定を空にして FIREBASE_CONFIG=null を強制し、
# 実 Firestore（.env は本番）に絶対に接続しない LocalStorage モードでテストする。
# （Vitest は mode=test のためこのファイルが .env を上書きする）
# 実 onSnapshot/writeBatch の結合検証は Firebase Emulator（層②）へ委ねる。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
